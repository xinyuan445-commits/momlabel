    -->
    
    <!-- 
    Oracle 示例
    <add key="DbConnectionType" value="Oracle" />
    <add key="DbConnectionString" value="Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=127.0.0.1)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL)));User Id=your_user;Password=your_password;" />
    -->
  </appSettings>
</configuration>